# Copy this file to .env and fill in real values.

# Django core
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Avoid '$' in values — Docker Compose treats it as a variable reference.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — omit to use SQLite (db.sqlite3). For PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/job_automation

# System-wide default minimum salary (used when a user sets no override)
DEFAULT_MIN_SALARY=30000

# Timezone the UI renders timestamps in (IANA name, e.g. Asia/Karachi,
# Europe/London, America/New_York). Timestamps are stored in UTC and converted for
# display, so changing this never rewrites history. Leave it unset and you get
# Europe/London, which is what makes the Search Runs clock look wrong elsewhere.
TIME_ZONE=Europe/London

# Third-party integrations
APIFY_API_TOKEN=
OPENAI_API_KEY=
# Google Sheets logging: one tab per candidate in a single sheet.
# In Docker the credentials dir is mounted at /app/credentials.
GOOGLE_SHEETS_CREDENTIALS_JSON=/app/credentials/google-service-account.json
GOOGLE_SHEET_ID=your_google_sheet_id

# Job search tuning (optional — sensible defaults apply)
APIFY_JOBS_ACTOR=memo23/apify-uk-jobs-aggregator
# Keyword/role the jobs actor searches for (doggo/uk-jobs-board-scraper requires one).
APIFY_SEARCH_KEYWORD=software engineer
OPENAI_MATCH_MODEL=gpt-4o-mini
OPENAI_TAILOR_MODEL=gpt-4o-mini
MAX_JOBS_PER_SEARCH=200
# Cap the number of jobs whose keyword contract is extracted by OpenAI (cost
# control). Every job is still scored and shown; the rest use the cheap
# deterministic contract.
OPENAI_MAX_SCORED_JOBS=50
# Jobs scoring at/above this threshold get a tailored CV + PDF generated. Jobs
# below it are still shown, with their real score — nothing is filtered out.
MATCH_THRESHOLD=75

# The only optional job filter, and it is off by default. True = jobs paying above
# your stated maximum are dropped from the results; False = they are shown with an
# "above salary preference" flag, which is almost always what you want.
SALARY_HARD_FILTER=False

# ---------------------------------------------------------------------------
# ATS checker  (scores jobs; never rejects them)
# ---------------------------------------------------------------------------
# A tailored CV scoring below this is reported as "below threshold". Advisory:
# no job is withheld from your results whatever it scores.
ATS_THRESHOLD=75

# Tailoring aims for this ATS score, re-running with the checker's feedback when
# the first draft falls short. A target, never a promise: where the candidate
# genuinely lacks the skills the advert asks for, the honest ceiling is lower, and
# the true score is kept and flagged rather than fabricated up to the target.
ATS_TARGET_SCORE=80

# Extra tailoring passes spent chasing ATS_TARGET_SCORE (each = 1 OpenAI call/job).
ATS_MAX_TAILOR_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Celery / Redis (async processing)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Override broker/backend individually if needed (default to REDIS_URL):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Run tasks inline without a worker (handy for local dev without Redis):
CELERY_TASK_ALWAYS_EAGER=False

# ---------------------------------------------------------------------------
# Email (search-completion notifications)
# ---------------------------------------------------------------------------
SEND_COMPLETION_EMAIL=False
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=no-reply@job-automation.local

# ---------------------------------------------------------------------------
# Logging & monitoring
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# Optional Sentry error tracking (leave blank to disable):
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Production (used when DEBUG=False)
# ---------------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# ---------------------------------------------------------------------------
# PostgreSQL (used by docker-compose)
# ---------------------------------------------------------------------------
POSTGRES_DB=job_automation
POSTGRES_USER=jobuser
POSTGRES_PASSWORD=jobpass


# Timezone used to render timestamps (stored in UTC). e.g. Europe/London, America/New_York
TIME_ZONE=Europe/London
